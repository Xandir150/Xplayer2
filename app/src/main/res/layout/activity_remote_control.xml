<?xml version="1.0" encoding="utf-8"?>
<!-- Remote layout: a fixed touchpad zone on top (eyes-free control while wearing the goggles —
     tap/swipe gestures with haptic feedback), and the button rows below it (sighted control /
     D-pad on a TV box driving the glasses as a second screen). Sized to fit one phone screen
     with no scrolling on typical devices; the ScrollView is a safety net for small/old phones. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/rc_bg"
    android:fitsSystemWindows="true">

    <!-- Header: app mark + now-playing title (fixed, compact) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="10dp"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/rc_on_surface"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/remote_now_playing" />
    </LinearLayout>

    <!-- Swappable control block: button transport (default, page 0) <-> touchpad (page 1). Only
         THIS block slides between the two — the rest of the remote (seekbar, cards, stop) stays
         put. Switched by swiping or tapping the pill handle at the bottom of the card, never by
         a gesture over the pages themselves (the touchpad's own swipes already mean seek/volume). -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="@color/rc_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/rc_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ViewFlipper
                android:id="@+id/remoteFlipper"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <!-- Page 0 (default — always usable without touch, e.g. D-pad on a TV box).
                     The buttons stay fully functional; a gesture layer sits BEHIND them (added
                     first, so it never steals a real button tap — it only sees touches that miss
                     every button) offering the same YouTube-style shortcuts as the touchpad page:
                     tap empty space = play/pause, swipe or double-tap left/right = ±10 s. No
                     volume gesture here — that stays touchpad-only. -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <FrameLayout
                        android:id="@+id/buttonPageGestureArea"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Last-action feedback ( ⏸ / +10 s ), above the buttons so it never
                             covers them. -->
                        <TextView
                            android:id="@+id/tvButtonPageFeedback"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|center_horizontal"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/rc_on_surface"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:alpha="0" />

                        <!-- Below the buttons, not behind them — centered it was hidden under the
                             transport row. -->
                        <TextView
                            android:id="@+id/tvButtonPageHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="10dp"
                            android:gravity="center"
                            android:text="@string/remote_button_page_hint"
                            android:textColor="@color/rc_secondary"
                            android:textSize="13sp"
                            android:alpha="0.65"
                            android:lineSpacingExtra="6dp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageButton
                            android:id="@+id/btnRewind"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_media_rew"
                            android:tint="@color/rc_on_surface"
                            android:scaleType="centerInside"
                            android:contentDescription="@string/player_rewind" />

                        <ImageButton
                            android:id="@+id/btnPlayPause"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginStart="22dp"
                            android:layout_marginEnd="22dp"
                            android:background="@drawable/bg_play_fab"
                            android:src="@android:drawable/ic_media_pause"
                            android:tint="@android:color/white"
                            android:scaleType="centerInside"
                            android:contentDescription="@string/player_play_pause" />

                        <ImageButton
                            android:id="@+id/btnForward"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_media_ff"
                            android:tint="@color/rc_on_surface"
                            android:scaleType="centerInside"
                            android:contentDescription="@string/player_forward" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Page 1: the eyes-free touchpad. -->
                <FrameLayout
                    android:id="@+id/touchpad"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Idle hint (always faintly visible under the feedback text) -->
                    <TextView
                        android:id="@+id/tvTouchHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="@string/remote_touchpad_hint"
                        android:textColor="@color/rc_secondary"
                        android:textSize="13sp"
                        android:alpha="0.65"
                        android:lineSpacingExtra="6dp" />

                    <!-- Big last-action feedback ( ⏸ / +10 s / volume % ), fades out after each gesture -->
                    <TextView
                        android:id="@+id/tvTouchFeedback"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="@color/rc_on_surface"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:alpha="0" />
                </FrameLayout>
            </ViewFlipper>

            <!-- Handle: tap to switch between the button page and the touchpad (a plain click —
                 a swipe here used to also fire performClick() underneath it, double-toggling
                 and flipping straight back, which read as a glitch).
                 NOT focusable: a D-pad (TV box, no touch at all) must never be able to land here
                 and flip to the touchpad page, which has no D-pad equivalent at all — that would
                 be a dead end. Still tappable directly (a click listener doesn't need focusable). -->
            <LinearLayout
                android:id="@+id/pageHandle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:contentDescription="@string/remote_page_handle_desc">

                <ImageView
                    android:id="@+id/iconButtonsPage"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_remote_gen_24"
                    android:contentDescription="@null" />

                <View
                    android:layout_width="16dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/rc_outline" />

                <ImageView
                    android:id="@+id/iconTouchpadPage"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_swipe_24"
                    android:contentDescription="@null" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Sized (via weight, below) to just about equal its natural content height on a typical
         phone screen so it doesn't need to actually scroll; still a weighted ScrollView so it
         degrades gracefully (internal scroll, not clipped content) on smaller screens. -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="14dp">

            <!-- Floating scrub readout: target timecode (+ speed when slowed) while dragging the
                 seekbar. Occupies its slim strip permanently (alpha 0 when idle) so appearing
                 doesn't shift the layout. -->
            <TextView
                android:id="@+id/tvScrubInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/rc_on_surface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:alpha="0"
                android:text="0:00" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:progressTint="?attr/colorPrimary"
                android:thumbTint="?attr/colorPrimary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvPosition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/rc_secondary"
                    android:textSize="12sp"
                    android:text="0:00" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/rc_secondary"
                    android:textSize="12sp"
                    android:text="0:00" />
            </LinearLayout>

            <!-- Controls card: display/3D settings + audio/subtitles, merged into one card to
                 save the per-card padding/title overhead the two-card layout used to cost. -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/rc_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/rc_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/remote_section_display"
                        android:textAppearance="@style/TextAppearance.XPlayer.Section" />

                    <!-- Row: stereo-mode cycle | Shift (Shift appears only in OU→SBS; when it's gone the
                         mode button expands to fill the row). -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSbs"
                            style="@style/Widget.XPlayer.RemoteRow"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:text="@string/remote_ou_to_sbs"
                            android:checkable="true" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShift"
                            style="@style/Widget.XPlayer.RemoteRow"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:text="@string/remote_shift"
                            android:checkable="true"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Row: aspect ratio | quality (quality appears only for multi-quality sources). -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnResizeMode"
                            style="@style/Widget.XPlayer.RemoteRow"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:text="@string/remote_auto"
                            app:icon="@drawable/ic_aspect_ratio_24" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnQuality"
                            style="@style/Widget.XPlayer.RemoteRow"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:text="@string/quality"
                            app:icon="@drawable/ic_quality_24"
                            android:visibility="gone" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="10dp"
                        android:background="@color/rc_outline" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/remote_section_audio"
                        android:textAppearance="@style/TextAppearance.XPlayer.Section" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAudio"
                            style="@style/Widget.XPlayer.RemoteIconRow"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:contentDescription="@string/remote_audio_track"
                            app:icon="@drawable/ic_translate_24" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSubtitle"
                            style="@style/Widget.XPlayer.RemoteIconRow"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:contentDescription="@string/menu_subtitle"
                            app:icon="@drawable/ic_subtitle_24" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVolumeBoost"
                            style="@style/Widget.XPlayer.RemoteIconRow"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:text="+0"
                            app:icon="@drawable/ear_sound_24px" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stop — kept to half width and centred so it's hard to hit by accident. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="2"
                    android:text="@string/remote_stop_playback"
                    android:textAllCaps="false"
                    android:textColor="@color/rc_danger"
                    app:icon="@drawable/ic_stop"
                    app:iconTint="@color/rc_danger"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/rc_danger" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
