<?xml version="1.0" encoding="utf-8"?>
<!--
    Supported XR glasses VID/PID list, mirrored from wheaney/XRLinuxDriver.
    Android-side 2D/3D switching is implemented for XREAL (open MCU protocol),
    VITURE (bundled SDK) and Rokid (open vendor control-transfer protocol) —
    see GlassesController. Other brands are detected so the UI can show a
    brand-specific message instead of nothing.
-->
<resources>
    <!-- XREAL: VID 0x3318 (decimal 13080) -->
    <usb-device vendor-id="13080" product-id="1060" />  <!-- 0x0424 Air -->
    <usb-device vendor-id="13080" product-id="1064" />  <!-- 0x0428 Air 2 -->
    <usb-device vendor-id="13080" product-id="1074" />  <!-- 0x0432 Air 2 Pro -->
    <usb-device vendor-id="13080" product-id="1062" />  <!-- 0x0426 Air 2 Ultra -->
    <usb-device vendor-id="13080" product-id="1077" />  <!-- 0x0435 One Pro -->
    <usb-device vendor-id="13080" product-id="1078" />  <!-- 0x0436 One Pro -->
    <usb-device vendor-id="13080" product-id="1079" />  <!-- 0x0437 One -->
    <usb-device vendor-id="13080" product-id="1080" />  <!-- 0x0438 One -->
    <usb-device vendor-id="13080" product-id="1086" />  <!-- 0x043e One S -->

    <!-- VITURE: VID 0x35ca (decimal 13770) -->
    <usb-device vendor-id="13770" product-id="4113" />  <!-- 0x1011 One -->
    <usb-device vendor-id="13770" product-id="4115" />  <!-- 0x1013 One -->
    <usb-device vendor-id="13770" product-id="4119" />  <!-- 0x1017 One -->
    <usb-device vendor-id="13770" product-id="4117" />  <!-- 0x1015 One Lite -->
    <usb-device vendor-id="13770" product-id="4123" />  <!-- 0x101b One Lite -->
    <usb-device vendor-id="13770" product-id="4121" />  <!-- 0x1019 Pro -->
    <usb-device vendor-id="13770" product-id="4125" />  <!-- 0x101d Pro -->
    <usb-device vendor-id="13770" product-id="4401" />  <!-- 0x1131 Luma -->
    <usb-device vendor-id="13770" product-id="4385" />  <!-- 0x1121 Luma Pro -->
    <usb-device vendor-id="13770" product-id="4417" />  <!-- 0x1141 Luma Pro -->
    <usb-device vendor-id="13770" product-id="4353" />  <!-- 0x1101 Luma Ultra -->
    <usb-device vendor-id="13770" product-id="4356" />  <!-- 0x1104 Luma Ultra -->
    <usb-device vendor-id="13770" product-id="4433" />  <!-- 0x1151 Luma Cyber -->
    <usb-device vendor-id="13770" product-id="4609" />  <!-- 0x1201 Beast -->

    <!-- Rokid: VID 0x04D2 (decimal 1234) — open vendor control-transfer 2D/3D switch, see
         GlassesController.sendRokidDisplayMode. -->
    <usb-device vendor-id="1234" product-id="5675" />  <!-- 0x162b Air/Max -->
    <usb-device vendor-id="1234" product-id="5676" />  <!-- 0x162c Air/Max -->
    <usb-device vendor-id="1234" product-id="5677" />  <!-- 0x162d Air/Max -->
    <usb-device vendor-id="1234" product-id="5678" />  <!-- 0x162e Air/Max -->
    <usb-device vendor-id="1234" product-id="5679" />  <!-- 0x162f Air/Max -->
    <usb-device vendor-id="1234" product-id="8194" />  <!-- 0x2002 Max 2 (unverified) -->
    <usb-device vendor-id="1234" product-id="8576" />  <!-- 0x2180 Max Pro (unverified) -->

    <!-- RayNeo (TCL): intentionally NOT listed here. We don't want Android to auto-launch XPlayer2
         or show the "open app / always open for this device" association dialog when RayNeo glasses
         are plugged in. RayNeo is still detected at runtime (GlassesController's broadcast receiver +
         deviceList) while the app is open, and the Air 3s Pro requests USB access lazily — only when
         the user actually switches 2D/3D from the glasses menu. -->
</resources>
