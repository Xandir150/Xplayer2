<?xml version="1.0" encoding="utf-8"?>
<!-- D-pad / TV focus highlight: a bright ring drawn (as a foreground) over focusable controls so
     it's obvious which one is selected. The platform's default focus highlight is too subtle. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FFEB3B" />
            <stroke android:width="4dp" android:color="#FFEB3B" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#FFEB3B" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
