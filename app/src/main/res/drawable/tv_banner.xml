<?xml version="1.0" encoding="utf-8"?>
<!-- Android TV banner (320x180dp). Gradient background + glasses icon.
     The TV launcher shows the app label underneath, so the banner stays icon-only. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <path
        android:pathData="M0,0 L320,0 L320,180 L0,180 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="320"
                android:endY="180"
                android:type="linear">
                <item android:offset="0" android:color="#FF1A0F2E" />
                <item android:offset="0.55" android:color="#FF2A1A4A" />
                <item android:offset="1" android:color="#FF6200EE" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Decorative concentric rings -->
    <path
        android:pathData="M260,40 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0"
        android:strokeColor="#22FFFFFF"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />
    <path
        android:pathData="M260,40 m-18,0 a18,18 0 1,0 36,0 a18,18 0 1,0 -36,0"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />

    <!-- Glasses icon centered, scaled from 24x24 viewbox to ~96x96 visual size -->
    <group
        android:translateX="112"
        android:translateY="42"
        android:scaleX="4"
        android:scaleY="4">
        <path
            android:fillColor="#FFFFFFFF"
            android:pathData="M3,10C3,8.9 3.9,8 5,8h14c1.1,0 2,0.9 2,2v4c0,1.1 -0.9,2 -2,2h-4.5c-0.4,0 -0.8,-0.2 -1,-0.5L12,13.5l-1.5,2C10.3,15.8 9.9,16 9.5,16H5c-1.1,0 -2,-0.9 -2,-2V10zM5,10v4h4.5l2,-2.7l2,2.7H19v-4H5z" />
    </group>

    <!-- Accent line -->
    <path
        android:pathData="M110,150 L210,150"
        android:strokeColor="#FFBB86FC"
        android:strokeWidth="2"
        android:strokeLineCap="round" />
</vector>
